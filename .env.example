# App: browser-safe public value
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Supabase public browser-safe configuration
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Supabase server-only secrets. Never expose these with NEXT_PUBLIC_ prefixes.
SUPABASE_SERVICE_ROLE_KEY="your-server-only-service-role-key"
SUPABASE_JWT_SECRET="your-server-only-supabase-jwt-secret"

# Database connection strings and Postgres fields. Server-only.
DATABASE_URL="postgresql://user:password@host:5432/database"
POSTGRES_URL="postgresql://user:password@host:5432/database"
POSTGRES_PRISMA_URL="postgresql://user:password@host:5432/database?pgbouncer=true"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/database"
POSTGRES_USER="your-postgres-user"
POSTGRES_HOST="your-postgres-host"
POSTGRES_PASSWORD="your-postgres-password"
POSTGRES_DATABASE="your-postgres-database"

# AI provider. Server-only. Do not call OpenAI until that feature is implemented.
OPENAI_API_KEY="your-server-only-openai-api-key"

# Optional GPT Actions / MCP auth. Server-only.
PANDORA_ACTIONS_API_KEY="your-server-only-actions-api-key"
MCP_SERVER_TOKEN="your-server-only-mcp-token"
