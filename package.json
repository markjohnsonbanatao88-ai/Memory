{
  "name": "pandora-memory-engine",
  "version": "0.1.0",
  "private": true,
  "description": "Pandora Memory Engine foundation: Next.js, TypeScript, Supabase, and Zod.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "npx --yes vitest@2.1.9 run",
    "test:watch": "npx --yes vitest@2.1.9",
    "ci": "npm run typecheck && npm run lint && npm run test && npm run build",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:lint": "supabase db lint",
    "db:types": "supabase gen types typescript --local > lib/supabase/database.types.ts",
    "db:push": "supabase db push --dry-run",
    "db:pull": "supabase db pull --schema public",
    "verify:first-reviewed-memory-fixture": "npx --yes tsx scripts/verify-first-reviewed-memory-fixture.ts",
    "env:policy": "npx --yes tsx scripts/check-env-policy.ts",
    "memory:smoke": "npx --yes tsx scripts/memory-smoke.ts",
    "memory:diagnostics": "npx --yes tsx scripts/memory-smoke.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@supabase/ssr": "^0.6.1",
    "@supabase/supabase-js": "^2.45.4",
    "lucide-react": "^1.23.0",
    "next": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.1.0",
    "@types/node": "^22.7.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.11.1",
    "eslint-config-next": "^15.0.0",
    "typescript": "^5.6.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
